# Copy to `.env` and adjust. Never commit `.env`.

# --- CLI demo (`make run` / `agentic-test`) ---
APP_ENV=development
DEBUG=false

# --- Microblog API (FastAPI + MongoDB) ---
# Local Docker MongoDB (after `make docker-up`): mongodb://127.0.0.1:27017
# In Compose stack (`make docker-api`): set to mongodb://mongo:27017 in compose only
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=microblog
MESSAGES_COLLECTION=messages

# Bind address/port for `pdm run microblog-api` / `make run-api-local`
API_HOST=0.0.0.0
API_PORT=8000

# Ping MongoDB on API startup (false in automated tests; true for local/Docker demos)
MONGODB_PING_ON_STARTUP=true

# Hot reload for local development: UVICORN_RELOAD=true
UVICORN_RELOAD=false

# --- Playwright API tests (optional; usually unset — see README) ---
# PLAYWRIGHT_SKIP_WEBSERVER=1
# API_BASE_URL=http://127.0.0.1:18080
# PLAYWRIGHT_API_PORT=18080
